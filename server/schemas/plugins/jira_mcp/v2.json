{
  "id": "jira_mcp",
  "label": "Jira MCP",
  "type": "mcp_http",
  "defaultName": "Jira MCP",
  "defaultUrl": "https://jira.example.com/mcp",
  "configSchema": {
    "type": "object",
    "required": [
      "apiToken",
      "email",
      "cloudId"
    ],
    "properties": {
      "apiToken": {
        "type": "string",
        "minLength": 1,
        "title": "API Token",
        "secret": true
      },
      "email": {
        "type": "string",
        "minLength": 3,
        "title": "Account Email"
      },
      "cloudId": {
        "type": "string",
        "minLength": 1,
        "title": "Cloud ID"
      }
    }
  },
  "version": 2
}
